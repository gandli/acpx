#!/bin/sh
# Husky hook to automatically remove Co-authored-by lines from commit messages

COMMIT_MSG_FILE="$1"

# Create a temporary file without Co-authored-by lines
TEMP_FILE=$(mktemp)
grep -v "^Co-authored-by:" "$COMMIT_MSG_FILE" > "$TEMP_FILE"
cat "$TEMP_FILE" > "$COMMIT_MSG_FILE"
rm -f "$TEMP_FILE"
